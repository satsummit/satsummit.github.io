{
  "name": "satsummit.io",
  "version": "3.0.0",
  "private": true,
  "description": "satsummit.io",
  "keywords": [
    "gatsby"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satsummit/satsummit.github.io"
  },
  "author": {
    "name": "Development Seed",
    "url": "https://developmentseed.org/"
  },
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/satsummit/satsummit.github.io/issues"
  },
  "homepage": "http://satsummit.io/",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "develop": "NODE_OPTIONS=--max-old-space-size=8192 gatsby develop -p $(node port.js) -H 0.0.0.0",
    "build": "node people-avatar-process.mjs && NODE_OPTIONS=--max-old-space-size=8192 gatsby build --prefix-paths && git checkout content/people/*/media",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "ts-check": "tsc --noEmit",
    "lint": "eslint src --no-error-on-unmatched-pattern",
    "theme": "npx @chakra-ui/cli typegen src/theme/index.ts"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.0.0",
    "@devseed-ui/collecticons-chakra": "^4.0.0",
    "@devseed-ui/hug-chakra": "^2.0.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.11.0",
    "@mdx-js/react": "^3.0.0",
    "@turf/bbox-polygon": "^7.1.0",
    "@turf/bearing": "^7.1.0",
    "@turf/boolean-point-in-polygon": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@types/mapbox-gl": "^3.0.0",
    "@types/mdx": "^2.0.12",
    "date-fns": "^4.0.0",
    "framer-motion": "^12.0.0",
    "gatsby": "^5.16.1",
    "gatsby-plugin-alias-imports": "^1.0.5",
    "gatsby-plugin-gdpr-cookies": "^2.0.9",
    "gatsby-plugin-google-gtag": "^5.13.1",
    "gatsby-plugin-google-tagmanager": "^5.13.1",
    "gatsby-plugin-image": "^3.13.1",
    "gatsby-plugin-mdx": "^5.13.1",
    "gatsby-plugin-sharp": "^5.13.1",
    "gatsby-plugin-webfonts": "^2.3.2",
    "gatsby-remark-copy-linked-files": "^6.13.1",
    "gatsby-remark-images": "^7.13.1",
    "gatsby-source-filesystem": "^5.13.1",
    "gatsby-transformer-sharp": "^5.13.1",
    "gatsby-transformer-yaml-full": "^5.0.0",
    "mapbox-gl": "^3.1.2",
    "polished": "^4.2.2",
    "react": "^19.0.0",
    "react-awesome-reveal": "^4.3.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-external-links": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-inclusive-language": "^2.2.1",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.0",
    "glob": "^13.0.0",
    "globals": "^16.0.0",
    "js-yaml": "^4.1.0",
    "portscanner": "^2.2.0",
    "prettier": "^3.2.4",
    "typescript": "^6.0.0"
  },
  "alias": {
    "$components": "./src/components",
    "$templates": "./src/templates",
    "$pages": "./src/pages",
    "$images": "./src/images",
    "$context": "./src/context",
    "$utils": "./src/utils"
  }
}
